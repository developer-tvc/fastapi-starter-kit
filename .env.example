
APP_NAME=FastAPI_Skeleton
DESCRIPTION=Production-ready FastAPI starter template with Clean Architecture
DEBUG=False
SECRET_KEY=Your secret key
DATABASE_URL=postgresql://user:password@host:port/db_name

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=10080
SWAGGER_LOGIN="/api/v1/auth/token"



SMTP_SERVER = "smtp.gmail.com"
SMTP_PORT = 587
SMTP_USERNAME = "your-email@gmail.com"
SMTP_PASSWORD = "your-app-password"

EMAIL_VERIFICATION_ENABLED=True


LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_ENABLED=True
LOGIN_LOCK_MINUTES=15

SMS_NOTIFICATION_ENABLED=False
IN_APP_NOTIFICATION_ENABLED=True
WEBHOOK_NOTIFICATION_ENABLED=False

SMS_PROVIDER=mock
SMS_API_KEY=
SMS_SENDER_ID=MyApp


MAX_WEBHOOK_RETRIES = 3
WEBHOOK_RETRY_DELAY = 2


CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

ALLOWED_IPS=["192.168.1.10", "127.0.0.1"]
IP_WHITELIST_ENABLED=True

PASSWORD_RESET_LINK = "http://localhost:3000/reset-password"
EMAIL_VERIFICATION_LINK = "http://localhost:3000/verify-email"


ENVIRONMENT=sandbox

TESTING_EMAIL=[""]

LIVE_MODE=True